# Copy this file to .env and fill in the values
# .env is gitignored and must NEVER be committed

# Path to the snapshot directory containing:
# applications-primary-db.csv, contracts.csv, properties.csv, units.csv, SNAPSHOT.json
# Example flat export: /Users/andre/neybor-conversion-v2/data/raw
# Example dated export: /Users/andre/neybor-conversion-v2/data/raw/2026-04-27
SNAPSHOT_DIR=

# Random seed for reproducibility (default: 42)
RANDOM_SEED=42

# (Optional, for later) Salesforce credentials if you switch from CSV to live SOQL
SF_USERNAME=
SF_PASSWORD=
SF_TOKEN=
SF_DOMAIN=login
